{
  "name": "unilms-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "UniLMS - Open-Source Learning Management System for Indian Engineering Colleges",
  "workspaces": [
    "apps/web",
    "apps/api",
    "packages/database",
    "packages/types"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w api\" \"npm run dev -w web\"",
    "build": "npm run build --workspaces --if-present",
    "start": "npm run start --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "db:generate": "npm run -w packages/database generate",
    "db:migrate": "npm run -w packages/database migrate",
    "postinstall": "npm run db:generate"
  },
  "keywords": [
    "lms",
    "nextjs",
    "nestjs",
    "supabase",
    "prisma",
    "copo-mapping",
    "engineering"
  ],
  "author": "UniLMS Team",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^10.0.3",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "prisma": "^6.19.3",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3"
  }
}
