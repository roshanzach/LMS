datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

/// The 6 distinct roles defined for UniLMS.
enum UserRole {
  SUPER_ADMIN
  COLLEGE_ADMIN
  HOD
  FACULTY
  CLASS_ADVISOR
  STUDENT
}

model College {
  id          String       @id @default(uuid()) @db.Uuid
  name        String
  code        String       @unique
  departments Department[]
  users       User[]
  courses     Course[]
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@map("colleges")
}

model Department {
  id          String       @id @default(uuid()) @db.Uuid
  name        String
  code        String
  collegeId   String       @db.Uuid @map("college_id")
  college     College      @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  users       User[]
  courses     Course[]
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@unique([collegeId, code])
  @@map("departments")
}

model User {
  id           String       @id @default(uuid()) @db.Uuid
  email        String       @unique
  username     String?      @unique @map("username")
  passwordHash String       @map("password_hash")
  firstName    String       @map("first_name")
  lastName     String       @map("last_name")
  role         UserRole     @default(STUDENT)
  isActive     Boolean      @default(true) @map("is_active")
  
  collegeId    String?      @db.Uuid @map("college_id")
  college      College?     @relation(fields: [collegeId], references: [id])
  departmentId String?      @db.Uuid @map("department_id")
  department   Department?  @relation(fields: [departmentId], references: [id])
  
  studentProfile StudentProfile?
  facultyProfile FacultyProfile?

  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  @@index([email])
  @@index([role])
  @@map("users")
}

model StudentProfile {
  id              String             @id @default(uuid()) @db.Uuid
  userId          String             @unique @db.Uuid @map("user_id")
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  enrollmentNo    String             @unique @map("enrollment_no")
  batchYear       Int                @map("batch_year")
  currentSemester Int                @map("current_semester")
  
  enrollments     CourseEnrollment[]
  
  @@map("student_profiles")
}

model FacultyProfile {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @unique @db.Uuid @map("user_id")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  employeeId      String    @unique @map("employee_id")
  designation     String
  
  coursesTeaching Course[]
  
  @@map("faculty_profiles")
}

model Course {
  id             String      @id @default(uuid()) @db.Uuid
  code           String
  name           String
  credits        Int
  collegeId      String      @db.Uuid @map("college_id")
  college        College     @relation(fields: [collegeId], references: [id])
  departmentId   String      @db.Uuid @map("department_id")
  department     Department  @relation(fields: [departmentId], references: [id])
  
  facultyId      String?     @db.Uuid @map("faculty_id")
  faculty        FacultyProfile? @relation(fields: [facultyId], references: [id])
  
  enrollments    CourseEnrollment[]
  
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  @@unique([collegeId, code])
  @@map("courses")
}

model CourseEnrollment {
  id             String         @id @default(uuid()) @db.Uuid
  studentId      String         @db.Uuid @map("student_id")
  courseId       String         @db.Uuid @map("course_id")
  student        StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course         Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrolledAt     DateTime       @default(now()) @map("enrolled_at")
  
  @@unique([studentId, courseId])
  @@map("course_enrollments")
}
